{
  "expo": {
    "name": "OnCallShift",
    "slug": "oncallshift",
    "scheme": "oncallshift",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8FAFC"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.oncallshift.mobile",
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification"],
        "NSFaceIDUsageDescription": "Use Face ID to quickly unlock the app"
      }
    },
    "android": {
      "package": "com.oncallshift.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#475569"
      },
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT"
      ]
    },
    "plugins": [
      "expo-notifications",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow OnCallShift to use Face ID for quick authentication"
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "oncallshift-mobile",
          "organization": "oncallshift"
        }
      ]
    ],
    "updates": {
      "enabled": false
    },
    "extra": {
      "eas": {
        "projectId": "your-project-id-here"
      },
      "sentryDsn": "https://your-sentry-dsn@o0.ingest.sentry.io/0"
    }
  }
}
