{
  "expo": {
    "name": "OnCallShift",
    "slug": "oncallshift-ft2ynzapva2fgiwgezhv1",
    "scheme": "oncallshift",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8FAFC"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.oncallshift.mobile",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification",
          "audio"
        ],
        "NSFaceIDUsageDescription": "Use Face ID to quickly unlock the app"
      },
      "entitlements": {
        "com.apple.developer.usernotifications.critical-alerts": true
      }
    },
    "android": {
      "package": "com.oncallshift.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#475569"
      },
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "ACCESS_NOTIFICATION_POLICY",
        "USE_FULL_SCREEN_INTENT",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#E53E3E"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow OnCallShift to use Face ID for quick authentication"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-secure-store"
    ],
    "updates": {
      "enabled": true,
      "url": "https://u.expo.dev/7311a48c-3b87-4bb8-8bba-549de8a578e7"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "7311a48c-3b87-4bb8-8bba-549de8a578e7"
      }
    },
    "owner": "jarod.rosenthal"
  }
}
