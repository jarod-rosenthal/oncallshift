{
  "expo": {
    "name": "OnCallShift",
    "slug": "oncallshift-ft2ynzapva2fgiwgezhv1",
    "scheme": "oncallshift",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8FAFC"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.oncallshift.mobile",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification",
          "audio"
        ],
        "NSFaceIDUsageDescription": "Use Face ID to quickly unlock the app"
      },
      "entitlements": {
        "com.apple.developer.usernotifications.critical-alerts": true
      }
    },
    "android": {
      "package": "com.oncallshift.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#475569"
      },
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "ACCESS_NOTIFICATION_POLICY",
        "USE_FULL_SCREEN_INTENT",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#E53E3E"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow OnCallShift to use Face ID for quick authentication"
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "oncallshift-mobile",
          "organization": "oncallshift"
        }
      ],
      "@react-native-community/datetimepicker",
      "@sentry/react-native",
      "expo-secure-store"
    ],
    "updates": {
      "enabled": false
    },
    "extra": {
      "sentryDsn": "https://your-sentry-dsn@o0.ingest.sentry.io/0",
      "eas": {
        "projectId": "7311a48c-3b87-4bb8-8bba-549de8a578e7"
      }
    },
    "owner": "jarod.rosenthal"
  }
}
