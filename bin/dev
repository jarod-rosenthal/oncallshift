#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

log() { echo -e "${BLUE}[dev]${NC} $1"; }
success() { echo -e "${GREEN}[dev]${NC} $1"; }
warn() { echo -e "${YELLOW}[dev]${NC} $1"; }
error() { echo -e "${RED}[dev]${NC} $1"; }

cleanup() {
  log "Shutting down services..."
  kill $BACKEND_PID $FRONTEND_PID 2>/dev/null || true
  docker compose -f "$ROOT_DIR/docker-compose.dev.yml" stop 2>/dev/null || true
  success "All services stopped."
}
trap cleanup EXIT INT TERM

# Load .env if it exists
if [ -f "$ROOT_DIR/.env" ]; then
  log "Loading .env file..."
  set -a
  source "$ROOT_DIR/.env"
  set +a
fi

# Start PostgreSQL
log "Starting PostgreSQL..."
docker compose -f "$ROOT_DIR/docker-compose.dev.yml" up -d --wait

success "PostgreSQL is ready on port 5433"

# Run migrations (if migrate script exists and backend is installed)
if [ -f "$ROOT_DIR/backend/node_modules/.bin/tsx" ]; then
  if [ -f "$ROOT_DIR/backend/src/shared/db/migrate.ts" ]; then
    log "Running database migrations..."
    (cd "$ROOT_DIR/backend" && npx tsx src/shared/db/migrate.ts) || warn "Migrations skipped (no migrations defined yet)"
  fi

  # Run seed (if seed script exists)
  if [ -f "$ROOT_DIR/backend/src/shared/db/seed.ts" ]; then
    log "Running database seed..."
    (cd "$ROOT_DIR/backend" && npx tsx src/shared/db/seed.ts) || warn "Seed skipped (seed not ready yet)"
  fi
fi

# Start backend
log "Starting backend on :3000..."
(cd "$ROOT_DIR/backend" && npm run dev) &
BACKEND_PID=$!

# Start frontend
log "Starting frontend on :5173..."
(cd "$ROOT_DIR/frontend" && npm run dev) &
FRONTEND_PID=$!

success "All services started!"
echo ""
echo -e "  ${GREEN}Frontend:${NC}   http://localhost:5173"
echo -e "  ${GREEN}Backend:${NC}    http://localhost:3000"
echo -e "  ${GREEN}PostgreSQL:${NC} localhost:5433"
echo ""
log "Press Ctrl+C to stop all services"

wait
