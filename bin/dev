#!/bin/bash
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT_DIR="$(dirname "$SCRIPT_DIR")"

echo "=== OnCallShift Local Development ==="
echo ""

# Start PostgreSQL
echo "[1/3] Starting PostgreSQL..."
docker compose -f "$ROOT_DIR/docker-compose.dev.yml" up -d
echo "  PostgreSQL running on port 5433"
echo ""

# Wait for PostgreSQL to be ready
echo "  Waiting for PostgreSQL to accept connections..."
until docker compose -f "$ROOT_DIR/docker-compose.dev.yml" exec -T postgres pg_isready -U oncallshift > /dev/null 2>&1; do
  sleep 1
done
echo "  PostgreSQL is ready."
echo ""

# Run migrations
echo "[2/3] Running database migrations..."
cd "$ROOT_DIR/backend"
npm run migrate 2>/dev/null || echo "  No migrations to run yet."
echo ""

# Start backend and frontend
echo "[3/3] Starting backend and frontend..."
echo "  Backend:  http://localhost:3000"
echo "  Frontend: http://localhost:5173"
echo ""

cd "$ROOT_DIR/backend" && npm run dev &
BACKEND_PID=$!

cd "$ROOT_DIR/frontend" && npm run dev &
FRONTEND_PID=$!

# Handle shutdown
cleanup() {
  echo ""
  echo "Shutting down..."
  kill $BACKEND_PID $FRONTEND_PID 2>/dev/null
  docker compose -f "$ROOT_DIR/docker-compose.dev.yml" stop
  exit 0
}

trap cleanup SIGINT SIGTERM

wait
