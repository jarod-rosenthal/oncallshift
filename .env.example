# =============================================================================
# OnCallShift Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# All AWS service values come from terraform outputs (Phase 0.1).
# =============================================================================

# --- Application ---
NODE_ENV=development
PORT=3000

# --- Database (local: Docker PostgreSQL on 5433) ---
DATABASE_URL=postgresql://oncallshift:localdev@localhost:5433/oncallshift

# --- AWS Region ---
AWS_REGION=us-east-2

# --- AWS Cognito (from terraform output) ---
COGNITO_USER_POOL_ID=us-east-2_XXXXXXXXX
COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# --- AWS SQS (from terraform output) ---
ALERTS_QUEUE_URL=https://sqs.us-east-2.amazonaws.com/593971626975/oncallshift-prod-alerts
NOTIFICATIONS_QUEUE_URL=https://sqs.us-east-2.amazonaws.com/593971626975/oncallshift-prod-notifications

# --- AWS SES ---
SES_FROM_EMAIL=noreply@oncallshift.com

# --- AWS SNS (from terraform output) ---
SNS_PUSH_TOPIC_ARN=arn:aws:sns:us-east-2:593971626975:oncallshift-prod-push-events

# --- AWS S3 (from terraform output) ---
S3_UPLOADS_BUCKET=oncallshift-prod-uploads

# --- CORS ---
CORS_ORIGINS=http://localhost:5173

# --- Sentry (optional) ---
# SENTRY_DSN=

# --- Git (auto-populated in CI) ---
# GIT_COMMIT=
