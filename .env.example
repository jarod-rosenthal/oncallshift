# Database (Docker PostgreSQL for local dev)
DATABASE_URL=postgresql://oncallshift:localdev@localhost:5433/oncallshift

# AWS Region (all managed services in us-east-2)
AWS_REGION=us-east-2

# AWS Cognito
COGNITO_USER_POOL_ID=us-east-2_CHANGEME
COGNITO_CLIENT_ID=CHANGEME

# AWS SQS Queue URLs
ALERTS_QUEUE_URL=https://sqs.us-east-2.amazonaws.com/ACCOUNT_ID/oncallshift-prod-alerts
NOTIFICATIONS_QUEUE_URL=https://sqs.us-east-2.amazonaws.com/ACCOUNT_ID/oncallshift-prod-notifications

# AWS SES
SES_FROM_EMAIL=noreply@oncallshift.com

# AWS SNS
SNS_PUSH_TOPIC_ARN=arn:aws:sns:us-east-2:ACCOUNT_ID:oncallshift-prod-push-events

# AWS S3
S3_UPLOADS_BUCKET=oncallshift-prod-uploads

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173

# Server
PORT=3000
NODE_ENV=development
