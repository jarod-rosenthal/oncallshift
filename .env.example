# =============================================================================
# OnCallShift — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in values.
# All AWS service values come from Terraform outputs after running:
#   cd infrastructure/terraform/environments/dev && terraform output
# =============================================================================

# -----------------------------------------------------------------------------
# Database (local Docker PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://oncallshift:localdev@localhost:5433/oncallshift

# -----------------------------------------------------------------------------
# Backend Server
# -----------------------------------------------------------------------------
PORT=3000
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173

# -----------------------------------------------------------------------------
# AWS General
# -----------------------------------------------------------------------------
AWS_REGION=us-east-2
# AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY are read from ~/.aws/credentials
# or set via environment. Do NOT commit real credentials.

# -----------------------------------------------------------------------------
# AWS Cognito (Auth)
# -----------------------------------------------------------------------------
COGNITO_USER_POOL_ID=us-east-2_REPLACE_ME
COGNITO_CLIENT_ID=REPLACE_ME

# -----------------------------------------------------------------------------
# AWS SQS (Queues)
# -----------------------------------------------------------------------------
ALERTS_QUEUE_URL=https://sqs.us-east-2.amazonaws.com/593971626975/oncallshift-dev-alerts
NOTIFICATIONS_QUEUE_URL=https://sqs.us-east-2.amazonaws.com/593971626975/oncallshift-dev-notifications

# -----------------------------------------------------------------------------
# AWS SES (Email)
# -----------------------------------------------------------------------------
SES_FROM_EMAIL=noreply@oncallshift.com

# -----------------------------------------------------------------------------
# AWS SNS (Push Notifications)
# -----------------------------------------------------------------------------
SNS_PUSH_TOPIC_ARN=arn:aws:sns:us-east-2:593971626975:oncallshift-dev-push-events

# -----------------------------------------------------------------------------
# AWS S3 (File Uploads)
# -----------------------------------------------------------------------------
S3_UPLOADS_BUCKET=oncallshift-dev-uploads

# -----------------------------------------------------------------------------
# Encryption
# -----------------------------------------------------------------------------
# Retrieved from AWS Secrets Manager: oncallshift-dev-encryption-key
ENCRYPTION_KEY=local-dev-encryption-key-replace-in-prod

# -----------------------------------------------------------------------------
# Sentry (Error Tracking) — optional for local dev
# -----------------------------------------------------------------------------
# SENTRY_DSN=

# -----------------------------------------------------------------------------
# Frontend (Vite env vars must start with VITE_)
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:3000
