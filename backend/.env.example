# Environment
NODE_ENV=development

# Server
PORT=3000

# Database
# Option 1: Direct connection string (for local development)
DATABASE_URL=postgres://username:password@localhost:5432/pagerduty_lite

# Option 2: AWS Secrets Manager (for production/ECS)
# DATABASE_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789:secret:pagerduty-lite-dev-db-password-xxxxx

# AWS
AWS_REGION=us-east-1

# SQS Queues
ALERTS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/pagerduty-lite-dev-alerts
NOTIFICATIONS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/pagerduty-lite-dev-notifications

# Cognito
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# SNS Platform Applications
# Leave empty if not configured yet
FCM_PLATFORM_APP_ARN=
APNS_PLATFORM_APP_ARN=

# CORS
CORS_ORIGIN=*

# Logging
LOG_LEVEL=info
