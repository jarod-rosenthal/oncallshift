# AI Worker Container
# Runs Claude Agent SDK to execute Jira tasks autonomously

FROM node:20-slim

# Install system dependencies
RUN apt-get update && apt-get install -y \
    git \
    curl \
    jq \
    openssh-client \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install GitHub CLI
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" | tee /etc/apt/sources.list.d/github-cli.list > /dev/null \
    && apt-get update \
    && apt-get install -y gh \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user
RUN useradd -m -s /bin/bash aiworker
WORKDIR /home/aiworker

# Install Claude Code CLI globally
RUN npm install -g @anthropic-ai/claude-code

# Copy entrypoint script
COPY scripts/ai-worker-entrypoint.sh /usr/local/bin/ai-worker-entrypoint.sh
RUN chmod +x /usr/local/bin/ai-worker-entrypoint.sh

# Switch to non-root user
USER aiworker

# Configure git
RUN git config --global user.name "AI Worker" && \
    git config --global user.email "ai-worker@oncallshift.com" && \
    git config --global init.defaultBranch main

# Set environment
ENV HOME=/home/aiworker
ENV NODE_ENV=production

ENTRYPOINT ["/usr/local/bin/ai-worker-entrypoint.sh"]
