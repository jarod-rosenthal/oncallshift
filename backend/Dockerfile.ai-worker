# AI Worker Container
# Runs Claude Agent SDK to execute Jira tasks autonomously
#
# This image includes all tools needed for the OnCallShift codebase:
# - Node.js, npm (base image)
# - Git, GitHub CLI
# - AWS CLI
# - Terraform
# - Go (for Terraform provider development)
# - Docker CLI (for container operations)
# - Common utilities: jq, curl, make, zip, unzip

FROM node:20-slim

# Set non-interactive frontend for apt
ENV DEBIAN_FRONTEND=noninteractive

# Install system dependencies and development tools
RUN apt-get update && apt-get install -y \
    git \
    curl \
    wget \
    jq \
    openssh-client \
    ca-certificates \
    gnupg \
    lsb-release \
    make \
    zip \
    unzip \
    python3 \
    python3-pip \
    build-essential \
    locales \
    && rm -rf /var/lib/apt/lists/*

# Configure UTF-8 locale for proper emoji/unicode support
RUN sed -i '/en_US.UTF-8/s/^# //g' /etc/locale.gen && \
    locale-gen
ENV LANG=en_US.UTF-8
ENV LC_ALL=en_US.UTF-8
ENV LANGUAGE=en_US:en

# Install GitHub CLI
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" | tee /etc/apt/sources.list.d/github-cli.list > /dev/null \
    && apt-get update \
    && apt-get install -y gh \
    && rm -rf /var/lib/apt/lists/*

# Install AWS CLI v2
RUN curl "https://awscli.amazonaws.com/awscli-exe-linux-$(uname -m).zip" -o "awscliv2.zip" \
    && unzip awscliv2.zip \
    && ./aws/install \
    && rm -rf awscliv2.zip aws

# Install Terraform
RUN wget -O- https://apt.releases.hashicorp.com/gpg | gpg --dearmor -o /usr/share/keyrings/hashicorp-archive-keyring.gpg \
    && echo "deb [signed-by=/usr/share/keyrings/hashicorp-archive-keyring.gpg] https://apt.releases.hashicorp.com $(lsb_release -cs) main" | tee /etc/apt/sources.list.d/hashicorp.list \
    && apt-get update \
    && apt-get install -y terraform \
    && rm -rf /var/lib/apt/lists/*

# Install Go (for Terraform provider development)
ENV GO_VERSION=1.22.0
RUN curl -fsSL "https://go.dev/dl/go${GO_VERSION}.linux-$(dpkg --print-architecture | sed 's/amd64/amd64/' | sed 's/arm64/arm64/').tar.gz" -o go.tar.gz \
    && tar -C /usr/local -xzf go.tar.gz \
    && rm go.tar.gz
ENV PATH="/usr/local/go/bin:${PATH}"
ENV GOPATH="/home/aiworker/go"
ENV PATH="${GOPATH}/bin:${PATH}"

# Install Docker CLI (for container operations, not running containers)
RUN curl -fsSL https://download.docker.com/linux/debian/gpg | gpg --dearmor -o /usr/share/keyrings/docker-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/docker-archive-keyring.gpg] https://download.docker.com/linux/debian $(lsb_release -cs) stable" | tee /etc/apt/sources.list.d/docker.list > /dev/null \
    && apt-get update \
    && apt-get install -y docker-ce-cli \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user and set up directories
RUN useradd -m -s /bin/bash aiworker \
    && mkdir -p /home/aiworker/go/bin /home/aiworker/go/pkg /home/aiworker/go/src \
    && chown -R aiworker:aiworker /home/aiworker
WORKDIR /home/aiworker

# Install Claude Code CLI globally
# The binary is named 'claude' not 'claude-code'
RUN npm install -g @anthropic-ai/claude-code

# Copy entrypoint script
COPY scripts/ai-worker-entrypoint.sh /usr/local/bin/ai-worker-entrypoint.sh
RUN chmod +x /usr/local/bin/ai-worker-entrypoint.sh

# Switch to non-root user
USER aiworker

# Configure git
RUN git config --global user.name "AI Worker" && \
    git config --global user.email "ai-worker@oncallshift.com" && \
    git config --global init.defaultBranch main

# Set environment
ENV HOME=/home/aiworker
ENV NODE_ENV=production
ENV PYTHONIOENCODING=utf-8

# Verify tools are installed (build-time check)
RUN echo "=== Installed Tools ===" && \
    node --version && \
    npm --version && \
    git --version && \
    gh --version && \
    aws --version && \
    terraform --version && \
    go version && \
    docker --version && \
    make --version | head -1 && \
    claude --version && \
    echo "=== All tools installed successfully ==="

ENTRYPOINT ["/usr/local/bin/ai-worker-entrypoint.sh"]
