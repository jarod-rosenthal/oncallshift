# AI Worker Container
# Runs Claude Agent SDK to execute Jira tasks autonomously
#
# This image includes all tools needed for the OnCallShift codebase:
# - Node.js, npm (base image)
# - Git, GitHub CLI
# - AWS CLI
# - Terraform
# - Go (for Terraform provider development)
# - Docker CLI (for container operations)
# - Kaniko (daemonless Docker image builder)
# - Common utilities: jq, curl, make, zip, unzip

# Kaniko stage - Copy executor binary from official Kaniko image
FROM gcr.io/kaniko-project/executor:v1.23.0 AS kaniko

FROM node:20-slim

# Set non-interactive frontend for apt
ENV DEBIAN_FRONTEND=noninteractive

# Install system dependencies and development tools
RUN apt-get update && apt-get install -y \
    git \
    curl \
    wget \
    jq \
    openssh-client \
    ca-certificates \
    gnupg \
    lsb-release \
    make \
    zip \
    unzip \
    python3 \
    python3-pip \
    build-essential \
    locales \
    && rm -rf /var/lib/apt/lists/*

# Configure UTF-8 locale for proper emoji/unicode support
RUN sed -i '/en_US.UTF-8/s/^# //g' /etc/locale.gen && \
    locale-gen
ENV LANG=en_US.UTF-8
ENV LC_ALL=en_US.UTF-8
ENV LANGUAGE=en_US:en

# Install GitHub CLI
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" | tee /etc/apt/sources.list.d/github-cli.list > /dev/null \
    && apt-get update \
    && apt-get install -y gh \
    && rm -rf /var/lib/apt/lists/*

# Install AWS CLI v2
RUN curl "https://awscli.amazonaws.com/awscli-exe-linux-$(uname -m).zip" -o "awscliv2.zip" \
    && unzip awscliv2.zip \
    && ./aws/install \
    && rm -rf awscliv2.zip aws

# Install Terraform
RUN wget -O- https://apt.releases.hashicorp.com/gpg | gpg --dearmor -o /usr/share/keyrings/hashicorp-archive-keyring.gpg \
    && echo "deb [signed-by=/usr/share/keyrings/hashicorp-archive-keyring.gpg] https://apt.releases.hashicorp.com $(lsb_release -cs) main" | tee /etc/apt/sources.list.d/hashicorp.list \
    && apt-get update \
    && apt-get install -y terraform \
    && rm -rf /var/lib/apt/lists/*

# Install Go (for Terraform provider development)
ENV GO_VERSION=1.22.0
RUN curl -fsSL "https://go.dev/dl/go${GO_VERSION}.linux-$(dpkg --print-architecture | sed 's/amd64/amd64/' | sed 's/arm64/arm64/').tar.gz" -o go.tar.gz \
    && tar -C /usr/local -xzf go.tar.gz \
    && rm go.tar.gz
ENV PATH="/usr/local/go/bin:${PATH}"
ENV GOPATH="/home/aiworker/go"
ENV PATH="${GOPATH}/bin:${PATH}"

# Install Docker CLI (for container operations, not running containers)
RUN curl -fsSL https://download.docker.com/linux/debian/gpg | gpg --dearmor -o /usr/share/keyrings/docker-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/docker-archive-keyring.gpg] https://download.docker.com/linux/debian $(lsb_release -cs) stable" | tee /etc/apt/sources.list.d/docker.list > /dev/null \
    && apt-get update \
    && apt-get install -y docker-ce-cli \
    && rm -rf /var/lib/apt/lists/*

# Copy Kaniko executor and full /kaniko directory from the kaniko stage
# Kaniko can build and push Docker images without requiring Docker daemon
COPY --from=kaniko /kaniko /kaniko
ENV PATH="/kaniko:${PATH}"
ENV DOCKER_CONFIG=/kaniko/.docker
ENV DOCKER_CREDENTIAL_GCR_CONFIG=/kaniko/.config/gcloud/docker_credential_gcr_config.json

# Create non-root user and set up directories
RUN useradd -m -s /bin/bash aiworker \
    && mkdir -p /home/aiworker/go/bin /home/aiworker/go/pkg /home/aiworker/go/src \
    && chown -R aiworker:aiworker /home/aiworker \
    && chown -R aiworker:aiworker /kaniko \
    && chmod -R 755 /kaniko
WORKDIR /home/aiworker

# Install Claude Code CLI globally
# The binary is named 'claude' not 'claude-code'
RUN npm install -g @anthropic-ai/claude-code

# Copy entrypoint scripts
COPY scripts/ai-worker-entrypoint.sh /usr/local/bin/ai-worker-entrypoint.sh
COPY scripts/ai-worker-manager-entrypoint.sh /usr/local/bin/ai-worker-manager-entrypoint.sh
RUN chmod +x /usr/local/bin/ai-worker-entrypoint.sh /usr/local/bin/ai-worker-manager-entrypoint.sh

# Copy DOE (Directive-Orchestration-Execution) framework
# These provide SOPs and deterministic execution scripts for AI workers
COPY ai-worker/AGENTS.md /app/AGENTS.md
COPY ai-worker/directives /app/directives
COPY ai-worker/execution /app/execution
COPY ai-worker/scripts /app/scripts

# Create package.json for execution scripts and install dependencies
RUN mkdir -p /app && \
    echo '{"name": "ai-worker-execution", "type": "module", "dependencies": {"typescript": "^5.0.0", "ts-node": "^10.9.0", "@types/node": "^20.0.0"}}' > /app/package.json && \
    cd /app && npm install

# Create tsconfig.json for compilation
RUN echo '{"compilerOptions": {"target": "ES2022", "module": "NodeNext", "moduleResolution": "NodeNext", "outDir": "./execution-compiled", "rootDir": "./execution", "strict": true, "esModuleInterop": true, "skipLibCheck": true, "declaration": false}, "include": ["execution/**/*.ts"]}' > /app/tsconfig.json

# Compile TypeScript execution scripts to JavaScript
RUN cd /app && npx tsc && \
    echo "[Build] Execution scripts compiled to /app/execution-compiled/"

# Fix ownership
RUN chown -R aiworker:aiworker /app

# Switch to non-root user
USER aiworker

# Configure git
RUN git config --global user.name "AI Worker" && \
    git config --global user.email "ai-worker@oncallshift.com" && \
    git config --global init.defaultBranch main

# Set environment
ENV HOME=/home/aiworker
ENV NODE_ENV=production
ENV PYTHONIOENCODING=utf-8

# Verify tools are installed (build-time check)
RUN echo "=== Installed Tools ===" && \
    node --version && \
    npm --version && \
    git --version && \
    gh --version && \
    aws --version && \
    terraform --version && \
    go version && \
    docker --version && \
    /kaniko/executor version && \
    make --version | head -1 && \
    claude --version && \
    echo "=== All tools installed successfully ==="

ENTRYPOINT ["/usr/local/bin/ai-worker-entrypoint.sh"]
