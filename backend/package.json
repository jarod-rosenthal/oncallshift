{
  "name": "oncallshift-backend",
  "version": "1.0.0",
  "description": "OnCallShift Backend API and Workers",
  "main": "dist/api/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/api/server.ts",
    "build": "tsc",
    "start": "node dist/api/server.js",
    "start:worker": "node dist/workers/notification-worker.js",
    "start:escalation-timer": "node dist/workers/escalation-timer.js",
    "start:snooze-expiry": "node dist/workers/snooze-expiry.js",
    "start:report-scheduler": "node dist/workers/report-scheduler.js",
    "migrate": "ts-node src/shared/db/migrate.ts",
    "migrate:create": "ts-node src/shared/db/create-migration.ts",
    "seed": "ts-node src/shared/db/seed.ts",
    "setup-contoso": "ts-node src/shared/db/setup-contoso-schedule.ts",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "test:integration": "jest --config jest.integration.config.js"
  },
  "keywords": [
    "incident-management",
    "on-call",
    "alerting"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@aws-sdk/client-cloudwatch-logs": "^3.958.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.470.0",
    "@aws-sdk/client-ec2": "^3.958.0",
    "@aws-sdk/client-ecs": "^3.958.0",
    "@aws-sdk/client-s3": "^3.958.0",
    "@aws-sdk/client-secrets-manager": "^3.470.0",
    "@aws-sdk/client-ses": "^3.470.0",
    "@aws-sdk/client-sns": "^3.470.0",
    "@aws-sdk/client-sqs": "^3.470.0",
    "@aws-sdk/client-sts": "^3.958.0",
    "@aws-sdk/s3-request-presigner": "^3.958.0",
    "@azure/arm-appservice": "^14.1.0",
    "@azure/arm-compute": "^21.6.0",
    "@azure/arm-containerservice": "^21.1.0",
    "@azure/identity": "^4.4.1",
    "@azure/monitor-query": "^1.3.1",
    "@google-cloud/compute": "^4.8.0",
    "@google-cloud/container": "^5.17.0",
    "@google-cloud/logging": "^11.2.0",
    "@google-cloud/run": "^1.5.0",
    "@sentry/node": "^10.32.1",
    "aws-jwt-verify": "^4.0.1",
    "axios": "^1.13.2",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "twilio": "^4.23.0",
    "typeorm": "^0.3.17",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.6",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.16.0",
    "@typescript-eslint/parser": "^6.16.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
